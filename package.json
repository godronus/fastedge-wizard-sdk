{
    "name": "@gcore/fastedge-wizard-sdk",
    "version": "0.1.1",
    "description": "Guest-side SDK for FastEdge wizards to talk to the host portal over the wizard bridge protocol.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "prepare": "tsc -p tsconfig.json",
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run"
    },
    "dependencies": {},
    "devDependencies": {
        "typescript": "5.9.3",
        "vitest": "^4.0.0"
    },
    "engines": {
        "node": ">=22"
    }
}
